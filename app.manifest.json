{
  "schema_version": "1.2.0",
  "app_id": "meiku",
  "app_name": "Meiku",
  "app_subtitle": "Profile Share",
  "primary_purpose": "Shares private and business contact details with local profile, contact and payment QR cards.",
  "app_symbol": "badge",
  "app_logo": {
    "src": "assets/meiku-logo-20260629.png",
    "favicon": "assets/meiku-favicon-20260629.png",
    "pwa_icon_192": "assets/meiku-icon-192-20260629.png",
    "pwa_icon_512": "assets/meiku-icon-512-20260629.png",
    "pwa_maskable_512": "assets/meiku-icon-512-20260629.png",
    "alt": "",
    "use_as_header_symbol": true,
    "use_as_favicon": true,
    "use_as_pwa_icon": true,
    "use_as_about_symbol": true,
    "use_as_profile_sheet_symbol": true,
    "use_as_empty_state_symbol": true
  },
  "default_theme": "lavender",
  "default_mode": "system",
  "has_account": true,
  "user_identity_fields": ["avatar", "initials", "display_name", "email"],
  "main_sections": [
    { "id": "privat", "label": "Private", "icon": "account_circle" },
    { "id": "firma", "label": "Company", "icon": "badge" },
    { "id": "payment", "label": "Payments", "icon": "account_balance_wallet" }
  ],
  "first_run_setup": {
    "enabled": false,
    "reason": "Meiku is not a server account system with an admin database. First run creates a locally encrypted profile vault; the server stores only the encrypted token.",
    "require_setup_secret": true,
    "setup_secret_file_env": "ISHIKU_SETUP_SECRET_FILE",
    "setup_secret_env": "ISHIKU_SETUP_SECRET",
    "setup_secret_file_default": "/run/secrets/ishiku_setup_secret"
  },
  "technical_info": {
    "allowed_locations": ["Settings", "Debug"],
    "disallowed_locations": ["AppHeader", "main footer"]
  },
  "navigation_complexity": "few_sections",
  "readme_profile": {
    "repository_name": "meiku",
    "github_owner": "MaroIshiku",
    "public_repository": true,
    "short_description": "Meiku is a self-hosted profile and contact card app in the Pixel Soft Utility design system.",
    "docker_image": "ghcr.io/maroishiku/meiku:latest",
    "codex_notice_enabled": true
  }
}
